{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowUserFolderAccess",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:ListBucket",
        "s3:DeleteObject"
      ],
      "Resource": [
        "arn:aws:s3:::demo-johndev1898-s3-cognito-users-storage/private/${cognito-identity.amazonaws.com:sub}/*"
      ]
    },
    {
      "Sid": "AllowListBucketIfSpecificPrefixIsIncluded",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::demo-johndev1898-s3-cognito-users-storage",
      "Condition": {
        "StringLike": {
          "s3:prefix": ["private/${cognito-identity.amazonaws.com:sub}/*"]
        }
      }
    }
  ]
}
